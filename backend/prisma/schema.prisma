generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  phone     String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  @@map("users")
}

enum Role {
  USER
  ADMIN
}
